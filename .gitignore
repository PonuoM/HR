*.csv

# ─── Debug / one-off scripts ───
# Ad-hoc DB inspection scripts (regenerated as needed)
check_*.php
test_db.php
test_*.php
# One-shot data recovery / recalc scripts
recalc_*.php
fix_*.php
# Underscore-prefixed PHP files = dev-only debug helpers
# (build-host.js skips them; never ship to prod)
api/_*.php
# DB schema inspection dumps
*cols.txt
cols.txt
